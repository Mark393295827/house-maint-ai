{
    "mcpServers": {
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@anthropic/mcp-server-filesystem"
            ],
            "env": {
                "ALLOWED_DIRECTORIES": "./"
            }
        },
        "github": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-github"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
            }
        },
        "memory": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-memory"
            ]
        }
    },
    "defaultServer": "filesystem",
    "serverOptions": {
        "autoConnect": true,
        "timeout": 30000,
        "retries": 3
    },
    "resources": {
        "filesystem": {
            "allowedPaths": [
                "./src",
                "./tests",
                "./scripts"
            ],
            "excludePaths": [
                "./node_modules",
                "./.git"
            ]
        }
    }
}