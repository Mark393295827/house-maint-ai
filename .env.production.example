# Production Environment Configuration
# Copy this file to .env.production and update the values

# Frontend API URL (your production API endpoint)
VITE_API_URL=https://api.your-domain.com/api

# Backend Configuration
PORT=3001
NODE_ENV=production

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Optional: CORS regex pattern for dynamic subdomains
# CORS_PATTERN=^https://.*\.your-domain\.com$

# Database (use Docker secrets for password in production)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_NAME=house_maint

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Optional: AI Services
# GOOGLE_AI_API_KEY=your-google-ai-api-key

# Optional: Sentry for error tracking
# SENTRY_DSN=your-sentry-dsn

# Optional: S3 Storage
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET=your-bucket-name

# Optional: Analytics
# MIXPANEL_TOKEN=your-mixpanel-token
