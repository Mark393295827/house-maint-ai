# 环境变量配置

# Database Configuration
# Use PostgreSQL for production:
DATABASE_URL=postgresql://housemaint:password@localhost:5432/housemaint
# Or leave empty to use SQLite for local development

# Backend Secrets (Server-side only)
GEMINI_API_KEY=your_gemini_api_key_here
SENTRY_DSN=your_backend_sentry_dsn

# Boolean to toggle strict rate limiting (optional)
# ENABLE_RATE_LIMIT=true

# Frontend Public Config (Vite)
VITE_API_BASE_URL=http://localhost:3001/api
VITE_SENTRY_DSN=your_frontend_sentry_dsn
VITE_MIXPANEL_TOKEN=your_mixpanel_token
