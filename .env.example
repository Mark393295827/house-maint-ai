# House Maint AI Environment Configuration
# Copy this file to .env and update the values for your environment

# =============================================================================
# Backend Server Configuration
# =============================================================================
PORT=3001
NODE_ENV=development

# JWT Secret - CHANGE THIS IN PRODUCTION!
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=house-maint-ai-local-secret

# =============================================================================
# Frontend Configuration (Vite Environment Variables)
# =============================================================================
# API endpoint for the frontend to connect to
VITE_API_URL=http://localhost:3001/api

# =============================================================================
# Database Configuration
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=house_maint

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Optional: Regex pattern for dynamic origins (e.g., subdomains)
# CORS_PATTERN=^https://.*\.example\.com$

# =============================================================================
# Optional: AI Services
# =============================================================================
# GOOGLE_AI_API_KEY=your-google-ai-api-key

# =============================================================================
# Optional: Error Tracking (Sentry)
# =============================================================================
# SENTRY_DSN=your-sentry-dsn

# =============================================================================
# Optional: S3 Storage (for file uploads)
# =============================================================================
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET=your-bucket-name

# =============================================================================
# Optional: Analytics
# =============================================================================
# MIXPANEL_TOKEN=your-mixpanel-token
